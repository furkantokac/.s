#!/usr/bin/env bash
# Bring down a generic SocketCAN interface
# Usage: s_cansocket_down <iface>
# Example: s_cansocket_down can0

set -euo pipefail

IFACE="${1:-}"

if [ -z "$IFACE" ]; then
  echo "Usage: s_cansocket_down <iface>"
  echo "Example: s_cansocket_down can0"
  exit 1
fi

if ! ip link show "${IFACE}" >/dev/null 2>&1; then
  echo "Interface \"${IFACE}\" does not exist. Nothing to do."
  exit 0
fi

STATE=$(ip -br link show "${IFACE}" | awk '{print $2}')
if [ "$STATE" = "DOWN" ]; then
  echo "Interface \"${IFACE}\" is already down."
  exit 0
fi

echo "Taking \"${IFACE}\" down..."
sudo ip link set down "${IFACE}"
echo "Interface \"${IFACE}\" is now down."
