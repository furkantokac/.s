#!/bin/bash
# ========================================
# Shared scripts config (~/.s/)
# Source this from other s_ scripts
# ========================================

# ============ Paths ============
S_LOG_DIR="$HOME/.s_logs"
S_BAK_DIR="$HOME/.s/_bak"

# ============ Colors ============
S_RED='\033[0;31m'
S_GREEN='\033[0;32m'
S_YELLOW='\033[1;33m'
S_CYAN='\033[0;36m'
S_BOLD='\033[1m'
S_NC='\033[0m'

# ============ Output ============
s_info()   { echo -e "${S_CYAN}ℹ${S_NC}  $*"; }
s_ok()     { echo -e "${S_GREEN}✓${S_NC}  $*"; }
s_warn()   { echo -e "${S_YELLOW}⚠${S_NC}  $*"; }
s_err()    { echo -e "${S_RED}✗${S_NC}  $*" >&2; }
s_header() { echo -e "\n${S_BOLD}$*${S_NC}"; }

# ============ Functions ============
s_ensure_dir() {
    mkdir -p "$1"
}

s_bytes_to_human() {
    local b=$1
    if (( b >= 1073741824 )); then
        echo "$(awk "BEGIN{printf \"%.1f\", $b/1073741824}") GB"
    elif (( b >= 1048576 )); then
        echo "$(awk "BEGIN{printf \"%.0f\", $b/1048576}") MB"
    else
        echo "$b B"
    fi
}
